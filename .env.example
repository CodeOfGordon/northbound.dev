# Copy to .env.local and fill in. .env.local is gitignored; this template is committed.

# ─────────────────────────────────────────────────────────────
# App runtime (read by Next.js / Mongoose)
# ─────────────────────────────────────────────────────────────

# MongoDB connection string — database/mongodb.ts reads process.env.MONGODB_URI
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/events_site

# Secret guarding POST /api/refresh (the cron scrape trigger). Use a long random string.
CRON_SECRET=

# PostHog (client-side analytics) — already wired in instrumentation-client.ts
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ─────────────────────────────────────────────────────────────
# MCP servers (read by .mcp.json — dev/agent tooling, NOT the app)
# ─────────────────────────────────────────────────────────────

# mongodb MCP — same connection string as MONGODB_URI
MDB_MCP_CONNECTION_STRING=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/events_site

# apify MCP — console.apify.com → Settings → API & Integrations
APIFY_TOKEN=

# brave-search MCP — api-dashboard.search.brave.com/app/keys (free tier ~2k queries/mo)
BRAVE_API_KEY=

# Per-source scrape cap (Apify actors are pay-per-result; keep modest). Default: 50
SCRAPE_MAX_ITEMS=50
